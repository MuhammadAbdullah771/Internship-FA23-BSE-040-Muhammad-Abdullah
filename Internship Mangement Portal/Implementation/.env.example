# =============================================================================
# InternHub — Unified MERN Stack Environment
# =============================================================================
# Copy to .env:  cp .env.example .env
# =============================================================================

NODE_ENV=development
PORT=5000

# -----------------------------------------------------------------------------
# MongoDB (choose ONE)
# -----------------------------------------------------------------------------

# Local
MONGODB_URI=mongodb://127.0.0.1:27017/internhub

# Atlas — replace <username>, <password>, <cluster>
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/internhub?retryWrites=true&w=majority&appName=InternHub

# -----------------------------------------------------------------------------
# Clerk (app: app_3G2KA7NKNZVgnZ33iYRugmANmnQ)
# Run: npm run clerk:login && npm run clerk:init && npm run clerk:env
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_CLERK_SIGN_IN_URL=/portal/student/login
VITE_CLERK_SIGN_UP_URL=/portal/student/signup
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portal/student
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portal/student

# -----------------------------------------------------------------------------
# JWT (legacy — optional if using Clerk only)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=internhub-dev-access-secret-change-in-production-32chars
JWT_REFRESH_SECRET=internhub-dev-refresh-secret-change-in-production-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
CLIENT_URL=http://localhost:5173

# React — dev uses Vite proxy to PORT (see vite.config.js)
VITE_API_URL=/api

# Production — same origin when using npm run start
# VITE_API_URL=/api
