{
  "name": "internhub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npx kill-port 5000",
    "predev:server": "npx kill-port 5000",
    "dev": "concurrently -n api,web -c green,blue \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/server.js",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/server.js",
    "stop": "npx kill-port 5000",
    "preview": "npm run build && npm run start",
    "seed": "node server/scripts/seed.js",
    "clerk:login": "clerk auth login",
    "clerk:init": "clerk init --app app_3G2KA7NKNZVgnZ33iYRugmANmnQ -y",
    "clerk:env": "clerk env pull",
    "clerk:doctor": "clerk doctor"
  },
  "dependencies": {
    "@clerk/backend": "^3.10.0",
    "@clerk/clerk-react": "^5.61.8",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^11.15.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "mongoose": "^8.9.3",
    "morgan": "^1.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "clerk": "^1.5.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.5"
  }
}
