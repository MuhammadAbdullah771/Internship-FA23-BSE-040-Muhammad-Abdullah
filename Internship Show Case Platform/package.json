{
  "name": "intern-showcase-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Intern Project Showcase Platform — full-stack MERN (Express + React)",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "npx vite --config client/vite.config.mjs",
    "build": "npx vite build --config client/vite.config.mjs",
    "start": "node server.js",
    "lint": "npx oxlint client/src"
  },
  "keywords": [
    "mern",
    "internship",
    "portfolio",
    "fullstack"
  ],
  "license": "ISC",
  "dependencies": {
    "@clerk/clerk-react": "^5.61.9",
    "@clerk/express": "^2.1.41",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "mongoose": "^9.7.4",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1"
  }
}
