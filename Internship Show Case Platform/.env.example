PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/intern_showcase
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/intern_showcase?retryWrites=true&w=majority

CLIENT_URL=http://localhost:5173
# Production (same host when Express serves the SPA):
# CLIENT_URL=https://your-app.example.com
# CORS_ORIGINS=https://www.your-app.example.com

CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Frontend (Vite reads these from the project root .env)
VITE_API_URL=/api
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
